---
import type { HTMLAttributes } from "astro/types";
import type { WithCSSProp } from "@lib/utils";
import { css } from "#styled-system/css";
import { avatarRecipe } from "./avatar.recipe";

type Props = WithCSSProp<HTMLAttributes<"span"> & { name: string }>;

const { name, css: cssProp, ...props } = Astro.props;
const classes = css(avatarRecipe.raw().fallback, cssProp);
const initials = name
    .split(" ")
    .map((n) => n[0])
    .join("")
    .toLocaleUpperCase();
---

<span class={classes} {...props}>{initials}</span>
