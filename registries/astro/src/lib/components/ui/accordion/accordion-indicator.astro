---
import { css } from "#styled-system/css";
import type { HTMLAttributes } from "astro/types";
import { accordionRecipe } from "./accordion.recipe";
import type { WithCSSProp } from "@lib/utils";

type Props = WithCSSProp<HTMLAttributes<"span">>;

const { css: cssProp, ...props } = Astro.props;

const classes = css(accordionRecipe.raw().indicator, cssProp);
// TODO: React to accordion item state changes
---

<span data-slot="accordion-trigger-icon" {...props}>+</span>
