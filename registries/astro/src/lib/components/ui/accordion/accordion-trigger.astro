---
import { css } from "#styled-system/css";
import type { HTMLAttributes } from "astro/types";
import { accordionRecipe } from "./accordion.recipe";
import AccordionIndicator from "./accordion-indicator.astro";
import type { WithCSSProp } from "@lib/utils";

type Props = WithCSSProp<HTMLAttributes<"div">>;

const { css: cssProp, ...props } = Astro.props;
const classes = css(accordionRecipe.raw().trigger, cssProp);
---

<div data-slot="accordion-trigger" {...props} class={classes}>
    <div class={accordionRecipe().triggerBody}>
        <slot />
    </div>
    <AccordionIndicator />
</div>
