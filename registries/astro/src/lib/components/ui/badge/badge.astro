---
import { cx } from "#styled-system/css";
import type { HTMLAttributes, HTMLTag, Polymorphic } from "astro/types";
import { badge, type BadgeVariants } from "./badge.recipe";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & BadgeVariants;

const { class: className, variant, size, pill, ...rest } = Astro.props;
const Tag = "href" in rest ? "a" : "button";
const classes = cx(badge({ variant, size, pill }), className);
---

<Tag class={classes} {...rest}>
    <slot />
</Tag>
