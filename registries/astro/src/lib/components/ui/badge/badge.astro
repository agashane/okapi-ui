---
import { css } from "#styled-system/css";
import type { HTMLAttributes, HTMLTag, Polymorphic } from "astro/types";
import { badge, type BadgeVariants } from "./badge.recipe";
import type { WithCSSProp } from "@lib/utils";

type Props<Tag extends HTMLTag> = WithCSSProp<
    Polymorphic<{ as: Tag }> & BadgeVariants
>;

const { variant, size, pill, css: cssProp, ...rest } = Astro.props;
const Tag = "href" in rest ? "a" : "button";
const classes = css(badge.raw({ variant, size, pill }), cssProp);
---

<Tag class={classes} {...rest}>
    <slot />
</Tag>
