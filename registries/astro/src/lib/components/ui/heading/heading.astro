---
import type { HTMLTag, Polymorphic } from "astro/types";
import { css } from "#styled-system/css";
import { heading, type HeadingVariants } from "./heading.recipe";
import type { WithCSSProp } from "@lib/utils";

type Props<Tag extends HTMLTag = "h2"> = WithCSSProp<
    HeadingVariants & Polymorphic<{ as: Tag }>
>;

const {
    css: cssProp,
    class: className,
    as: Tag = "h2",
    level = "h2",
    ...props
} = Astro.props;
const classes = css(heading.raw({ level }), cssProp);
---

<Tag class={classes} {...props}>
    <slot />
</Tag>
