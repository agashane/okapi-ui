---
import { css } from "#styled-system/css";
import type { HTMLAttributes } from "astro/types";
import { accordionRecipe } from "./accordion.recipe";
import type { WithCSSProp } from "@lib/utils";

type Props = WithCSSProp<HTMLAttributes<"div">>;

const { css: cssProp, ...props } = Astro.props;
const classes = css(accordionRecipe.raw().content, cssProp);
---

<div data-slot="accordion-content" {...props} class={classes}>
    <slot />
</div>
