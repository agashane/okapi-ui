---
import type { HTMLAttributes } from "astro/types";
import type { WithCSSProp } from "@lib/utils";
import { css } from "#styled-system/css";
import { avatarRecipe } from "./avatar.recipe";

type Props = WithCSSProp<HTMLAttributes<"div">>;

const { css: cssProp, ...props } = Astro.props;
const classes = css(avatarRecipe.raw().group, cssProp);
---

<div data-group-item class={classes} {...props}>
    <slot />
</div>
