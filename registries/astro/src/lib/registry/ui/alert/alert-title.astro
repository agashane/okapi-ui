---
import type { ComponentProps } from "astro/types";
import { Heading } from "../heading";
import { css } from "#styled-system/css";
import { alertVariants } from "./alert.recipe";
import type { WithCSSProp } from "@lib/utils";

type Props = WithCSSProp<ComponentProps<typeof Heading>>;

const { css: cssProp, level = "h6", as = "h6", ...props } = Astro.props;
const classes = css(alertVariants.raw().title, cssProp);
---

<Heading level={level} as={as} class={classes} {...props}><slot /></Heading>
